<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Breadcrumbs</masterLabel>
    <description>Displays a horizontal navigational path.</description>

    <targets>
        <target>lightning__RecordPage</target>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightningCommunity__Default</target>
        <target>lightningCommunity__Page</target>
    </targets>

    <targetConfigs>
        <!-- Config for Experience Builder & Record Pages -->
             <targetConfig targets="lightningCommunity__Default">
            <property name="levels" type="String" label="Breadcrumb Levels"
                      description='Enter comma-separated labels, e.g. "Home, Knowledge, Article"'/>
            <property name="links" type="String" label="Breadcrumb Links"
                      description='Enter comma-separated URLs or merge fields, e.g. "/", "/knowledge", "/article/{!urlName}"'/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>