<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Create Record Form</masterLabel>
    <description>Reusable component to create Salesforce records directly from a page.</description>

    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__HomePage</target>
        <target>lightningCommunity__Default</target>
        <target>lightningCommunity__Page</target>
    </targets>

    <!-- ✅ Property configuration (Note: no lightningCommunity__Page here) -->
    <targetConfigs>
        <targetConfig
            targets="lightning__AppPage,lightning__RecordPage,lightning__HomePage,lightningCommunity__Default">

            <property name="actionName"
                      type="String"
                      label="Action Name"
                      description="Label for the action button"
                      default="Create Record" />

            <property name="objectApiName"
                      type="String"
                      label="Object API Name"
                      description="e.g., Account, Contact, Case"
                      default="Account" />

            <property name="recordTypeId"
                      type="String"
                      label="Record Type Id"
                      description="Optional Record Type Id" />

            <property name="fields"
                      type="String"
                      label="Fields (comma separated)"
                      description="Example: Name, Phone, Website"
                      default="Name,Phone,Website" />

            <property name="batchMode"
                      type="Boolean"
                      label="Create Records in Batches"
                      description="(Optional placeholder for batch mode)"
                      default="false" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>